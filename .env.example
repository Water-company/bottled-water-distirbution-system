# Runtime environment. Use local only on a developer machine; safe production value: production.
DJANGO_ENV=local

# Required outside local dev. Safe production value: a long random secret generated per deployment.
DJANGO_SECRET_KEY=

# Django debug mode. Safe production value: False.
DJANGO_DEBUG=True

# Comma-separated hosts Django will serve. Safe production value: your real domain names only.
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# Send session cookies only over HTTPS. Safe production value: True.
DJANGO_SESSION_COOKIE_SECURE=False

# Send CSRF cookies only over HTTPS. Safe production value: True.
DJANGO_CSRF_COOKIE_SECURE=False

# Force HTTPS redirects at Django level. Safe production value: True.
DJANGO_SECURE_SSL_REDIRECT=False

# HTTP Strict Transport Security max-age in seconds. Safe production value: 31536000 or higher.
DJANGO_SECURE_HSTS_SECONDS=0

# Apply HSTS to subdomains too. Safe production value: True when all subdomains are HTTPS-ready.
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=False

# Trust the upstream proxy's HTTPS header. Safe production value: True behind a correctly configured reverse proxy.
DJANGO_SECURE_PROXY_SSL_HEADER_ENABLED=False

# Proxy header name Django should trust for HTTPS detection. Safe production value: HTTP_X_FORWARDED_PROTO.
DJANGO_SECURE_PROXY_SSL_HEADER_NAME=HTTP_X_FORWARDED_PROTO

# Proxy header value that means the original request used HTTPS. Safe production value: https.
DJANGO_SECURE_PROXY_SSL_HEADER_VALUE=https

# Clickjacking protection header. Safe production value: DENY unless your app must be framed.
DJANGO_X_FRAME_OPTIONS=DENY

CHAPA_SECRET_KEY=
CHAPA_BASE_URL=https://api.chapa.co/v1
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=your-email@gmail.com
CHAPA_PUBLIC_KEY=
NOMINATIM_CONTACT_EMAIL=
